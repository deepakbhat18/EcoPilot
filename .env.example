# =========================================================================
# EcoPilot ESG Platform Environment Configurations
# =========================================================================

# Database Setup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecopilot

# Security Configuration
JWT_SECRET_KEY=super_secret_jwt_signing_key_for_ecopilot_development_only_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenRouter AI Integrations (Configured securely backend-side)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=1500
OPENROUTER_TIMEOUT=30
